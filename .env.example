# Variabili d'ambiente per il progetto e-Trentin
# Copia questo file in .env e compila con le tue credenziali Supabase

# URL del progetto Supabase (es. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=https://tuo-progetto.supabase.co

# Chiave anonima pubblica (anon key) — NON usare mai la service_role key nel frontend
VITE_SUPABASE_PUBLISHABLE_KEY=tua-chiave-anon-pubblica
